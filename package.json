{
  "name": "insys-websocket-bidstream",
  "version": "1.0.0",
  "private": true,
  "description": "WebSocket gateway for InSys gRPC BidStream",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.47",
    "@types/ws": "^8.5.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}